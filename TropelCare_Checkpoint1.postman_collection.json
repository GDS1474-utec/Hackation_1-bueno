{
  "info": {
    "name": "TropelCare Checkpoint 1",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "sectorId",
      "value": "1"
    },
    {
      "key": "tropelId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "1. GET guardians",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/guardians"
      }
    },
    {
      "name": "2. POST sector capacity 1",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"sectorCode\": \"SECTOR-7\",\n  \"climate\": \"RETRO_ARCADE\",\n  \"capacity\": 1\n}"
        },
        "url": "{{baseUrl}}/api/v1/sectors"
      }
    },
    {
      "name": "3. POST tropel BipBop",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"BipBop\",\n  \"species\": \"GLITCHY\",\n  \"sectorId\": 1,\n  \"guardianId\": 1\n}"
        },
        "url": "{{baseUrl}}/api/v1/tropels"
      }
    },
    {
      "name": "4. GET sector 1",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/sectors/1"
      }
    },
    {
      "name": "5. POST second tropel should return 400",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"ByteByte\",\n  \"species\": \"CHISPA\",\n  \"sectorId\": 1,\n  \"guardianId\": 1\n}"
        },
        "url": "{{baseUrl}}/api/v1/tropels"
      }
    },
    {
      "name": "6. GET tropels filtered by vitalState",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/tropels?vitalState=ESTABLE&page=0&size=10"
      }
    }
  ]
}